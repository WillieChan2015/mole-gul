{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mole GUI",
  "version": "0.3.0",
  "identifier": "com.mole-gui.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mole GUI",
        "width": 800,
        "height": 600,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../resources/**/*"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/WillieChan2015/mole-gui/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU1MzAwRkQwNEYzN0I2MDYKUldUb09rUXJvQm1HdmVhWENRWFBOT1NVTWVWZ1pMdWhwWVZqSGFrQWxkMGRvclhGd25CMFVGdEEK"
    }
  }
}
